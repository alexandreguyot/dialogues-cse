# =====================================================================
# Dialogues CSE — production environment template.
# =====================================================================

APP_NAME="Dialogues CSE"
APP_ENV=production
APP_KEY=                          # echo "base64:$(openssl rand -base64 32)"
APP_DEBUG=false
APP_URL=https://dialogues-cse.fr

APP_HOST=dialogues-cse.fr

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR
APP_TIMEZONE=Europe/Paris

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=dialogues_cse
DB_USERNAME=dialogues_cse
DB_PASSWORD=                       # set in _infra MySQL bootstrap (create-db.sh)

CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@dialogues-cse.fr"
MAIL_FROM_NAME="${APP_NAME}"

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# reCAPTCHA (anhskohbo/no-captcha) — fill if you actually use it
NOCAPTCHA_SITEKEY=
NOCAPTCHA_SECRET=
